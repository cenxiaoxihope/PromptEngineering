<h4>知识点</h4>
<p><strong>Throwable</strong> 分为 <strong>Error</strong>（严重问题，不处理）和 <strong>Exception</strong>。<strong>受检异常（Checked）</strong>必须显式处理或声明，如 <code>IOException</code>；<strong>非受检异常（Unchecked）</strong>继承 <code>RuntimeException</code>，如 <code>NullPointerException</code>。<code>try-with-resources</code> 自动关闭实现 <code>AutoCloseable</code> 的资源。</p>

<h4>可运行代码示例</h4>
<pre><code class="java">package com.example.day15;

import java.io.*;

public class ExceptionHandling {
    
    public static String readConfig(String path) throws IOException {
        try (BufferedReader reader = new BufferedReader(new FileReader(path))) {
            StringBuilder sb = new StringBuilder();
            String line;
            while ((line = reader.readLine()) != null) {
                sb.append(line).append("\n");
            }
            return sb.toString();
        }
    }
    
    public static int parseAge(String input) {
        try {
            int age = Integer.parseInt(input);
            if (age &lt; 0 || age &gt; 150) {
                throw new IllegalArgumentException("年龄必须在0-150之间");
            }
            return age;
        } catch (NumberFormatException e) {
            System.err.println("输入格式错误: " + e.getMessage());
            return -1;
        } catch (IllegalArgumentException e) {
            System.err.println("业务校验失败: " + e.getMessage());
            return -1;
        } finally {
            System.out.println("parseAge执行完成");
        }
    }
    
    public static void process() {
        try {
            riskyOperation();
        } catch (FileNotFoundException | IllegalStateException e) {
            System.out.println("可恢复异常: " + e.getClass().getSimpleName());
        }
    }
    
    static void riskyOperation() throws FileNotFoundException {
        if (System.currentTimeMillis() % 2 == 0) {
            throw new FileNotFoundException("文件不存在");
        }
    }
    
    public static void main(String[] args) {
        System.out.println("年龄解析: " + parseAge("abc"));
        System.out.println("年龄解析: " + parseAge("200"));
        System.out.println("年龄解析: " + parseAge("25"));
        
        try {
            System.out.println(readConfig("nonexistent.txt"));
        } catch (IOException e) {
            System.out.println("读取失败，使用默认配置");
        }
    }
}
</code></pre>

