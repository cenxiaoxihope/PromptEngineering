<h4>核心代码骨架</h4>
<pre><code class="java">package com.example.week3;

import java.util.*;
import java.util.stream.*;

class Student {
    Long id; String name; String clazz;
    Student(Long id, String name, String clazz) {
        this.id = id; this.name = name; this.clazz = clazz;
    }
}

class Score {
    Long studentId; String course; Integer point;
    Score(Long sid, String course, Integer point) {
        this.studentId = sid; this.course = course; this.point = point;
    }
}

class ScoreService {
    private List&lt;Student&gt; students = new ArrayList&lt;&gt;();
    private List&lt;Score&gt; scores = new ArrayList&lt;&gt;();
    
    void addStudent(Student s) {
        if (s.name == null || s.name.isBlank())
            throw new IllegalArgumentException("姓名不能为空");
        students.add(s);
    }
    
    void addScore(Score sc) { scores.add(sc); }
    
    Map&lt;String, Double&gt; averageByCourse() {
        return scores.stream()
            .collect(Collectors.groupingBy(
                s -> s.course,
                Collectors.averagingInt(s -> s.point)
            ));
    }
    
    List&lt;Score&gt; findByStudent(Long sid) {
        return scores.stream()
            .filter(s -> s.studentId.equals(sid))
            .collect(Collectors.toList());
    }
    
    List&lt;String&gt; rankingByClazz(String clazz) {
        Set&lt;Long&gt; ids = students.stream()
            .filter(s -> s.clazz.equals(clazz))
            .map(s -> s.id)
            .collect(Collectors.toSet());
        
        return scores.stream()
            .filter(s -> ids.contains(s.studentId))
            .sorted(Comparator.comparingInt((Score s) -> s.point).reversed())
            .map(s -> s.studentId + ":" + s.course + "=" + s.point)
            .collect(Collectors.toList());
    }
}
</code></pre>

