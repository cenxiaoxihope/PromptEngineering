<div class="day-section">
<div class="day-title">第22天（D22）：Java IO流</div>
<div class="day-meta">预计3h理论 + 2h实践</div>

<h4>知识点</h4>
<p>IO流分为<strong>字节流</strong>（InputStream/OutputStream，适合二进制）和<strong>字符流</strong>（Reader/Writer，适合文本，自动编码）。《strong>Buffered流</strong>通过减少系统调用次数提升性能。<strong>序列化</strong>将对象转为字节流，需实现 <code>Serializable</code> 接口，<code>transient</code> 字段不序列化。</p>

<h4>可运行代码示例</h4>
<pre><code class="java">package com.example.day22;

import java.io.*;
import java.nio.file.*;

public class FileIO {
    
    // 使用Buffered流复制大文件
    public static void copyFile(String src, String dest) throws IOException {
        try (BufferedInputStream bis = new BufferedInputStream(new FileInputStream(src));
             BufferedOutputStream bos = new BufferedOutputStream(new FileOutputStream(dest))) {
            byte[] buffer = new byte[8192];
            int len;
            while ((len = bis.read(buffer)) != -1) {
                bos.write(buffer, 0, len);
            }
        }
    }
    
    // 序列化示例：用户偏好设置
    static class UserPreference implements Serializable {
        private static final long serialVersionUID = 1L;
        String theme;
        transient String tempToken; // 不序列化
        int fontSize;
        
        UserPreference(String theme, String token, int fontSize) {
            this.theme = theme; this.tempToken = token; this.fontSize = fontSize;
        }
    }
    
    public static void main(String[] args) throws Exception {
        // 复制文件
        Path temp = Files.createTempFile("test", ".txt");
        Files.writeString(temp, "Hello, Java IO!");
        copyFile(temp.toString(), temp.toString() + ".bak");
        System.out.println("复制完成");
        
        // 序列化与反序列化
        UserPreference pref = new UserPreference("dark", "secret123", 14);
        String serFile = "pref.ser";
        try (ObjectOutputStream oos = new ObjectOutputStream(new FileOutputStream(serFile))) {
            oos.writeObject(pref);
        }
        
        try (ObjectInputStream ois = new ObjectInputStream(new FileInputStream(serFile))) {
            UserPreference restored = (UserPreference) ois.readObject();
            System.out.println("主题: " + restored.theme);
            System.out.println("字体: " + restored.fontSize);
            System.out.println("临时令牌: " + restored.tempToken); // null
        }
        
        Files.deleteIfExists(Path.of(serFile));
    }
}
</code></pre>

