<div class="day-section">
<div class="day-title">第45天（D45）：RabbitMQ消息队列</div>
<div class="day-meta">预计3h理论 + 2h实践</div>

<h4>知识点</h4>
<p><strong>RabbitMQ</strong>核心概念：Exchange（交换机）、Queue（队列）、Binding（绑定）、Routing Key（路由键）。Exchange类型：direct（精确匹配）、fanout（广播）、topic（模式匹配）、headers（头匹配）。消息可靠性：生产者confirm、消费者ack、持久化。</p>

<h4>可运行代码示例</h4>
<pre><code class="java">package com.example.demo.mq;

import org.springframework.amqp.core.*;
import org.springframework.amqp.rabbit.annotation.RabbitListener;
import org.springframework.amqp.rabbit.core.RabbitTemplate;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.stereotype.Service;

@Configuration
class RabbitConfig {
    static final String QUEUE = "order.queue";
    static final String EXCHANGE = "order.exchange";
    static final String ROUTING_KEY = "order.created";
    
    @Bean Queue queue() { return new Queue(QUEUE, true); }
    @Bean DirectExchange exchange() { return new DirectExchange(EXCHANGE); }
    @Bean Binding binding(Queue q, DirectExchange ex) {
        return BindingBuilder.bind(q).to(ex).with(ROUTING_KEY);
    }
}

@Service
class OrderProducer {
    private final RabbitTemplate rabbitTemplate;
    
    OrderProducer(RabbitTemplate rabbitTemplate) { this.rabbitTemplate = rabbitTemplate; }
    
    public void sendOrder(String orderInfo) {
        rabbitTemplate.convertAndSend(RabbitConfig.EXCHANGE, RabbitConfig.ROUTING_KEY, orderInfo);
        System.out.println("发送订单消息: " + orderInfo);
    }
}

@Service
class OrderConsumer {
    @RabbitListener(queues = RabbitConfig.QUEUE)
    public void handleOrder(String message) {
        System.out.println("处理订单: " + message);
        // 异步处理：扣减库存、发送邮件等
    }
}
</code></pre>

