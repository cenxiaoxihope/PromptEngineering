<h4>关键代码：看板状态更新</h4>
<pre><code class="java">@PatchMapping("/{id}/status")
public ResponseEntity&lt;?&gt; updateStatus(@PathVariable Long id,
                                      @RequestBody @Valid StatusUpdateRequest request,
                                      @AuthenticationPrincipal String username) {
    Task task = taskService.findById(id);
    // 权限检查：项目成员才能更新
    projectService.checkMembership(task.getProjectId(), username);
    
    TaskStatus oldStatus = task.getStatus();
    taskService.updateStatus(id, request.status());
    
    // 发送通知（如果是别人分配的任务且状态变为DONE）
    if (oldStatus != TaskStatus.DONE && request.status() == TaskStatus.DONE
        && !task.getAssignee().equals(username)) {
        notificationService.send(task.getAssignee(), "任务已完成", task.getTitle());
    }
    
    return ResponseEntity.ok().build();
}
</code></pre>
