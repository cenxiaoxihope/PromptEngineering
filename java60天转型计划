<h4>知识点</h4>
<p><strong>JSR-380（Bean Validation 2.0）</strong>注解：<code>@NotNull</code>（非null）、<code>@NotBlank</code>（非空串）、<code>@Size</code>（长度范围）、<code>@Min/@Max</code>（数值范围）、<code>@Email</code>（邮箱格式）、<code>@Pattern</code>（正则）。在Controller参数前加 <code>@Valid</code> 触发校验。<strong>全局异常处理器</strong>用 <code>@RestControllerAdvice</code> + <code>@ExceptionHandler</code> 统一封装错误响应。</p>

<h4>可运行代码示例</h4>
<pre><code class="java">package com.example.demo.advice;

import org.springframework.http.HttpStatus;
import org.springframework.validation.FieldError;
import org.springframework.web.bind.MethodArgumentNotValidException;
import org.springframework.web.bind.annotation.*;
import java.time.LocalDateTime;
import java.util.*;

@RestControllerAdvice
public class GlobalExceptionHandler {
    
    @ExceptionHandler(MethodArgumentNotValidException.class)
    @ResponseStatus(HttpStatus.BAD_REQUEST)
    public ErrorResponse handleValidation(MethodArgumentNotValidException ex) {
        Map&lt;String, String&gt; errors = new HashMap&lt;&gt;();
        for (FieldError err : ex.getBindingResult().getFieldErrors()) {
            errors.put(err.getField(), err.getDefaultMessage());
        }
        return new ErrorResponse(400, "参数校验失败", errors, LocalDateTime.now());
    }
    
    @ExceptionHandler(NotFoundException.class)
    @ResponseStatus(HttpStatus.NOT_FOUND)
    public ErrorResponse handleNotFound(NotFoundException ex) {
        return new ErrorResponse(404, ex.getMessage(), null, LocalDateTime.now());
    }
    
    @ExceptionHandler(Exception.class)
    @ResponseStatus(HttpStatus.INTERNAL_SERVER_ERROR)
    public ErrorResponse handleGeneric(Exception ex) {
        return new ErrorResponse(500, "服务器内部错误", null, LocalDateTime.now());
    }
}

record ErrorResponse(int code, String message, Map&lt;String, String&gt; details, LocalDateTime timestamp) {}
</code></pre>

