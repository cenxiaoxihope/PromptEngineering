<h4>知识点</h4>
<p><code>BigDecimal</code> 必须用 <code>String</code> 构造（避免 <code>double</code> 精度问题）。<code>LocalDate</code>/<code>LocalTime</code>/<code>LocalDateTime</code> 是Java 8引入的不可变日期API，替代 <code>Date</code> 和 <code>Calendar</code>。格式化使用 <code>DateTimeFormatter</code>。</p>

<h4>可运行代码示例</h4>
<pre><code class="java">package com.example.day06;

import java.math.BigDecimal;
import java.math.RoundingMode;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.time.temporal.ChronoUnit;

public class BankDeposit {
    public static void main(String[] args) {
        BigDecimal principal = new BigDecimal("100000"); // 本金10万
        BigDecimal annualRate = new BigDecimal("0.035"); // 年利率3.5%
        int years = 3;
        LocalDate startDate = LocalDate.now();
        LocalDate endDate = startDate.plusYears(years);
        
        // 复利计算: A = P * (1 + r)^n
        BigDecimal multiplier = BigDecimal.ONE.add(annualRate);
        BigDecimal amount = principal;
        for (int i = 0; i < years; i++) {
            amount = amount.multiply(multiplier);
        }
        amount = amount.setScale(2, RoundingMode.HALF_UP);
        BigDecimal interest = amount.subtract(principal);
        
        DateTimeFormatter fmt = DateTimeFormatter.ofPattern("yyyy年MM月dd日");
        
        System.out.println("存款计算器");
        System.out.println("本金: " + principal);
        System.out.println("年利率: " + annualRate.multiply(new BigDecimal("100")) + "%");
        System.out.println("存期: " + years + "年");
        System.out.println("存入日期: " + startDate.format(fmt));
        System.out.println("到期日期: " + endDate.format(fmt));
        System.out.println("到期本息: " + amount);
        System.out.println("利息收入: " + interest);
        System.out.println("距今天数: " + ChronoUnit.DAYS.between(startDate, endDate));
    }
}
</code></pre>

