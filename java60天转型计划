<h4>知识点</h4>
<p>关联关系：<code>@OneToOne</code>（一对一）、<code>@OneToMany</code> + <code>@ManyToOne</code>（一对多）、<code>@ManyToMany</code>（多对多）。<strong>FetchType.LAZY</strong>（懒加载，默认除EAGER外）在访问时才查询，性能更优但需注意Session关闭后的LazyInitializationException。<strong>DTO（Data Transfer Object）</strong>用于层间数据传输，避免暴露实体全部字段。</p>

<h4>可运行代码示例</h4>
<pre><code class="java">package com.example.demo.entity;

import jakarta.persistence.*;
import java.util.ArrayList;
import java.util.List;

@Entity
public class Article {
    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;
    
    @Column(nullable = false)
    private String title;
    
    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "author_id")
    private UserEntity author;
    
    @OneToMany(mappedBy = "article", cascade = CascadeType.ALL, orphanRemoval = true)
    private List&lt;Comment&gt; comments = new ArrayList&lt;&gt;();
    
    @ManyToMany
    @JoinTable(
        name = "article_tags",
        joinColumns = @JoinColumn(name = "article_id"),
        inverseJoinColumns = @JoinColumn(name = "tag_id")
    )
    private List&lt;Tag&gt; tags = new ArrayList&lt;&gt;();
    
    // getters/setters omitted
}

@Entity
public class Comment {
    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;
    
    @Column(nullable = false, length = 1000)
    private String content;
    
    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "article_id")
    private Article article;
}

@Entity
public class Tag {
    @Id @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;
    
    @Column(unique = true)
    private String name;
}

