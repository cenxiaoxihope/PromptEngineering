<div class="day-title">第28天（D28）：周项目 — 多线程文件下载器</div>
<div class="day-meta">预计6h实践 | <span class="tag tag-project">周项目</span></div>

<h4>项目需求</h4>
<p>实现一个命令行多线程文件下载器：输入URL和线程数，将文件分片，每个线程下载一部分，最后合并。要求显示下载进度条，支持断点续传（通过HTTP Range头）。额外任务：下载完成后用BufferedReader统计文本文件中词频最高的10个词。</p>

<pre><code class="java">package com.example.week4;

import java.io.*;
import java.net.*;
import java.util.concurrent.*;

public class MultiThreadDownloader {
    private String url;
    private int threadCount;
    private String outputPath;
    
    MultiThreadDownloader(String url, int threads, String output) {
        this.url = url; this.threadCount = threads; this.outputPath = output;
    }
    
    void download() throws Exception {
        HttpURLConnection conn = (HttpURLConnection) new URL(url).openConnection();
        int totalSize = conn.getContentLength();
        conn.disconnect();
        
        ExecutorService pool = Executors.newFixedThreadPool(threadCount);
        int chunkSize = totalSize / threadCount;
        
        for (int i = 0; i &lt; threadCount; i++) {
            final int index = i;
            int start = index * chunkSize;
            int end = (index == threadCount - 1) ? totalSize - 1 : (start + chunkSize - 1);
            
            pool.submit(() -> {
                try {
                    HttpURLConnection c = (HttpURLConnection) new URL(url).openConnection();
                    c.setRequestProperty("Range", "bytes=" + start + "-" + end);
                    try (InputStream in = c.getInputStream();
                         RandomAccessFile raf = new RandomAccessFile(outputPath, "rw")) {
                        raf.seek(start);
                        byte[] buf = new byte[8192];
                        int len;
                        while ((len = in.read(buf)) != -1) {
                            raf.write(buf, 0, len);
                        }
                    }
                    System.out.println("线程" + index + "完成");
                } catch (IOException e) {
                    System.err.println("线程" + index + "失败: " + e.getMessage());
                }
            });
        }
        
        pool.shutdown();
        pool.awaitTermination(10, TimeUnit.MINUTES);
        System.out.println("下载完成: " + outputPath);
    }
    
    public static void main(String[] args) throws Exception {
        // 用本地文件模拟
        new MultiThreadDownloader("http://example.com/file.txt", 4, "downloaded.txt").download();
    }
}
</code></pre>

